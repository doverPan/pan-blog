---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/stones', label: '他山之石' },
  { href: '/projects', label: '项目' },
  { href: '/about', label: '关于' }
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <a class="brand" href="/">
    <span class="brand-mark">PJ</span>
    <span>
      <strong>Panjie</strong>
      <small>AI vibe coding</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="主导航">
    <ul>
      {navItems.map((item) => (
        <li>
          <a class={currentPath === item.href || currentPath.startsWith(`${item.href}/`) ? 'active' : ''} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

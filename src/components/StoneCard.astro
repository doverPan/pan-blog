---
import type { CollectionEntry } from 'astro:content';
import TagLink from './TagLink.astro';

type Props = {
  stone: CollectionEntry<'stones'>;
};

const { stone } = Astro.props;
---

<article class="post-card">
  <div class="post-card-top">
    <p>{stone.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
    <span class="pill">摘录</span>
  </div>
  <h3>
    <a href={`/stones/${stone.slug}/`}>{stone.data.title}</a>
  </h3>
  <p>{stone.data.description}</p>
  <p class="source-inline">
    来源：
    <a
      href={stone.data.sourceUrl}
      target="_blank"
      rel="noreferrer"
      data-analytics-event="source_click"
      data-analytics-label={stone.data.sourceName}
    >{stone.data.sourceName}</a>
    {stone.data.sourceAuthor && <span> · {stone.data.sourceAuthor}</span>}
  </p>
  <ul class="tag-list" aria-label="摘录标签">
    {stone.data.tags.map((tag: string) => <li><TagLink tag={tag} /></li>)}
  </ul>
</article>

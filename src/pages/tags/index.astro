---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags, isPublished, slugifyTag } from '../../utils/blog';

const tags = getAllTags((await getCollection('blog')).filter(isPublished));
---

<BaseLayout title="标签 | Panjie" description="按主题浏览文章。">
  <section class="page-intro narrow">
    <p class="eyebrow">标签</p>
    <h1>按主题查看内容。</h1>
    <p class="lede">把相关文章组织起来，方便别人快速理解你的技术覆盖范围。</p>
  </section>

  <ul class="tag-cloud">
    {tags.map((tag) => (
      <li>
        <a href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
      </li>
    ))}
  </ul>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import StoneCard from '../components/StoneCard.astro';
import { projects } from '../data/projects';
import { isPublished, sortPosts } from '../utils/blog';

const posts = sortPosts((await getCollection('blog')).filter(isPublished));
const stones = sortPosts((await getCollection('stones')).filter(isPublished));
const latestPosts = posts.slice(0, 4);
const latestStones = stones.slice(0, 4);
---

<BaseLayout
  title="Panjie | AI vibe coding 博客"
  description="一个围绕 AI vibe coding、工程实验、项目复盘与技术思考展开的个人博客。"
  mainClass="home-main"
>
  <section class="page-intro page-intro-editorial home-intro">
    <p class="eyebrow">AI vibe coding / engineering notes</p>
    <h1>Panjie 的技术博客</h1>
  </section>

  <section class="section-block section-editorial">
    <div class="section-heading">
      <p class="eyebrow">文章</p>
      <h2>原创文章</h2>
    </div>
    <div class="card-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="section-block section-library">
    <div class="section-heading">
      <p class="eyebrow">他山之石</p>
      <h2>外部摘录</h2>
    </div>
    <div class="card-grid">
      {latestStones.map((stone) => <StoneCard stone={stone} />)}
    </div>
  </section>

  <section class="section-block section-projects-home">
    <div class="section-heading">
      <p class="eyebrow">项目</p>
      <h2>项目展示</h2>
    </div>
    <div class="project-list">
      {projects.map((project) => (
        <article class="project-card">
          <h3>{project.name}</h3>
          <p>{project.summary}</p>
          <p class="project-meta"><strong>关注点：</strong>{project.focus}</p>
          <p class="project-meta"><strong>价值：</strong>{project.outcome}</p>
          <div class="project-actions">
            <a href="/projects" data-analytics-event="project_browse" data-analytics-label={project.name}>
              浏览项目详情
            </a>
            {project.link && (
              <a href={project.link} target="_blank" rel="noreferrer" data-analytics-event="project_click" data-analytics-label={project.name}>
                查看项目演示
              </a>
            )}
          </div>
          <ul class="tag-list" aria-label={`${project.name} stack`}>
            {project.stack.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
